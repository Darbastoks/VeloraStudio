# =============================================================
# VELORA STUDIO — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.
# =============================================================

# --- SERVER ---
PORT=3000
SITE_URL=https://yourdomain.lt

# --- STRIPE ---
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...

# Get this from: Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# --- STRIPE PRICE IDs ---
# How to create prices:
#   1. Stripe Dashboard → Products → Add product
#   2. Create 3 products: SOLO, GROWTH, TEAM
#   3. For each product, add 2 prices (monthly recurring + annual recurring)
#   4. Copy the price_xxx IDs below
#
#   SOLO:   €25/month  or  €199/year  (1 worker)
#   GROWTH: €39/month  or  €349/year  (up to 3 workers)
#   TEAM:   €59/month  or  €399/year  (unlimited workers)

STRIPE_PRICE_SOLO_MONTHLY=price_...
STRIPE_PRICE_SOLO_ANNUAL=price_...
STRIPE_PRICE_GROWTH_MONTHLY=price_...
STRIPE_PRICE_GROWTH_ANNUAL=price_...
STRIPE_PRICE_TEAM_MONTHLY=price_...
STRIPE_PRICE_TEAM_ANNUAL=price_...

# --- N8N WEBHOOK ---
# This is the webhook URL from your n8n payment workflow (07-payment.json)
# In n8n: open the workflow → Webhook node → copy the Production URL
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/stripe-payment
