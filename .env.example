# =============================================================
# VELORA STUDIO — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.
# =============================================================

# --- SERVER ---
PORT=3000
SITE_URL=https://yourdomain.lt

# --- STRIPE ---
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...

# Get this from: Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# --- BASE PLAN PRICE IDs ---
# Create 2 products in Stripe Dashboard:
#   1. "Beauty Website Solo" — 1 grožio specialistas
#   2. "Beauty Website Team" — keli darbuotojai
# For each product, add 2 prices (monthly recurring + annual recurring)
#
#   SOLO: €25/month  or  €199/year
#   TEAM: €59/month  or  €399/year

STRIPE_PRICE_SOLO_MONTHLY=price_...
STRIPE_PRICE_SOLO_ANNUAL=price_...
STRIPE_PRICE_TEAM_MONTHLY=price_...
STRIPE_PRICE_TEAM_ANNUAL=price_...

# --- ADD-ON PRICE IDs ---
# Create 5 add-on products in Stripe Dashboard:
#   1. "Add-on: Online Gift Cards"
#   2. "Add-on: Memberships"
#   3. "Add-on: SMS Reminders"
#   4. "Add-on: Inventory Management"
#   5. "Add-on: Product Selling"
# For each add-on, add 2 prices (monthly recurring + annual recurring)

STRIPE_PRICE_ADDON_GIFTCARDS_MONTHLY=price_...
STRIPE_PRICE_ADDON_GIFTCARDS_ANNUAL=price_...
STRIPE_PRICE_ADDON_MEMBERSHIPS_MONTHLY=price_...
STRIPE_PRICE_ADDON_MEMBERSHIPS_ANNUAL=price_...
STRIPE_PRICE_ADDON_SMS_MONTHLY=price_...
STRIPE_PRICE_ADDON_SMS_ANNUAL=price_...
STRIPE_PRICE_ADDON_INVENTORY_MONTHLY=price_...
STRIPE_PRICE_ADDON_INVENTORY_ANNUAL=price_...
STRIPE_PRICE_ADDON_PRODUCTS_MONTHLY=price_...
STRIPE_PRICE_ADDON_PRODUCTS_ANNUAL=price_...

# --- N8N WEBHOOK ---
# This is the webhook URL from your n8n payment workflow
# In n8n: open the workflow → Webhook node → copy the Production URL
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/stripe-payment
